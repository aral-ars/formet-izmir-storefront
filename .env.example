# ─── Sanity ────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Sanity project
# (create one free at https://www.sanity.io/manage — "Create new project").

# Project id + dataset. Safe to expose (used by the browser Studio + image CDN).
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"

# GROQ/query API version — a date. Bump deliberately.
NEXT_PUBLIC_SANITY_API_VERSION="2025-06-01"

# ─── Server-only secrets (never commit real values) ─────────────────────────
# Write token (Editor/Deploy role) — used ONLY by scripts/seed.ts to import the
# existing catalog. Not needed at runtime. Create at manage.sanity.io → API → Tokens.
SANITY_API_WRITE_TOKEN=""

# Shared secret for the /api/revalidate webhook. Generate any random string and
# set the same value on the Sanity webhook (manage.sanity.io → API → Webhooks).
SANITY_REVALIDATE_SECRET=""
